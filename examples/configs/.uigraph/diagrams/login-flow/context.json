{
  "name": "Auth state diagram context",
  "description": "Mock context for the authentication state diagram (complex-mermaid.txt): states and groups for Unauthenticated, LoginPending, MFA, Session, and Security flows.",
  "nodes": {
    "Unauthenticated": {
      "name": "Unauthenticated",
      "type": "cloud",
      "cloud": "AWS",
      "service": "Amazon Athena",
      "data": {
        "initial": { "type": "Boolean Toggle", "value": true },
        "label": { "type": "Text Input", "value": "Unauthenticated" }
      },
      "style" :{
        "fill": "#088ae7",
        "stroke": "#0076D2",
        "strokeWidth": 2,
        "borderRadius": 2,
        "strokeStyle": "dotted",
        "borderAnimationEnabled": true
      }
    },
    "LoginPending": {
      "name": "LoginPending",
      "data": {
        "label": { "type": "Text Input", "value": "LoginPending" },
        "url": { "type": "URL Input", "value": "https://example.com" },
        "otp_ttl": { "type": "Number Input", "value": 300 },
        "notes": { "type": "Text Editor", "value": "Multi-line notes" },
