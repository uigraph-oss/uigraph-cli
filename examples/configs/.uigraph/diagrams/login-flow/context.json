        "mfa_enabled": { "type": "Boolean Toggle", "value": false },
        "description": { "type": "Rich Text Editor", "value": "## Login pending state\n\nUser has **submitted credentials** and we are:\n- Validating against the identity provider\n- Checking MFA requirements\n- Applying rate limits\n\n*Next:* `auth_success` or `auth_failed`." },
        "config_json": { "type": "Code Editor", "value": "# Python: auth config\ndef get_login_config():\n    return {\n        \"mfa_required\": True,\n        \"max_attempts\": 5,\n        \"lockout_minutes\": 30,\n    }" },
        "handler_go": { "type": "Code Editor", "value": "// Go: login handler\nfunc (h *AuthHandler) HandleLoginPending(ctx context.Context, req *LoginRequest) error {\n\tif err := h.validateCredentials(req); err != nil {\n\t\treturn err\n\t}\n\treturn h.checkMFA(ctx, req.UserID)\n}" },
        "schema_sql": { "type": "Code Editor", "value": "-- MySQL: login sessions\nCREATE TABLE login_sessions (\n  id BINARY(16) PRIMARY KEY,\n  user_id BIGINT NOT NULL,\n  state ENUM('LoginPending', 'Authenticated') DEFAULT 'LoginPending',\n  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n);" },
        "headers": { "type": "Key-Value List", "value": [] },
        "tags": { "type": "Tag Input", "value": ["auth", "login"] },
        "active_period": { "type": "Date Range Picker", "value": null },
        "theme": { "type": "Color Picker", "value": "#1976D2" },
        "retry_count": { "type": "Slider", "value": 3 },
        "provider": { "type": "Search Select", "value": "local" },
        "permissions": { "type": "Checkbox Group", "value": ["read"], "options": ["read", "write"] }
      }
    },
